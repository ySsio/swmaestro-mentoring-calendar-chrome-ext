{
  "manifest_version": 3,
  "name": "소마 달력 뷰어",
  "description": "AI·SW마에스트로 접수내역을 달력 형식으로 표시합니다.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.swmaestro.ai/sw/mypage/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "calendar.css"
      ],
      "run_at": "document_idle"
    }
  ]
}